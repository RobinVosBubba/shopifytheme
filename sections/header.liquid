<header class="site-header">
  <div class="page-width">
    <div class="site-header__logo">
      <a href="{{ routes.root_url }}">
        {%- if settings.logo -%}
          <img
            src="{{ settings.logo | image_url: width: 320 }}"
            alt="{{ shop.name }}"
            width="{{ settings.logo_width }}"
            loading="eager"
          >
        {%- else -%}
          <span style="font-family:var(--font-heading);font-size:1.5rem;">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>
    <nav aria-label="Main navigation">
      <ul>
        {%- for link in section.settings.menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </nav>
    <a href="{{ routes.cart_url }}" class="site-header__cart" aria-label="Cart">
      Cart ({{ cart.item_count }})
    </a>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
