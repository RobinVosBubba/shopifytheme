<div class="hero">
  <div class="hero__media">
    {%- if section.settings.image -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        alt=""
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
      >
    {%- endif -%}
    <div class="hero__overlay"></div>
  </div>
  <div class="page-width">
    <div class="hero__content">
      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url }}" class="button">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Island life, one cup at a time" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Coffee, hospitality and the Koh Phangan way of living." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Coffee" },
    { "type": "url", "id": "button_url", "label": "Button link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
