<div class="section collection-grid page-width">
  {%- if section.settings.show_heading -%}
    <h1 class="collection-grid__heading">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-grid__description">{{ collection.description }}</div>
    {%- endif -%}
  {%- endif -%}

  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- if collection.products.size > 0 -%}
      <div class="product-grid" style="--grid-cols: {{ section.settings.columns_desktop }};">
        {%- for product in collection.products -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}">&larr; Previous</a>
          {%- endif -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}">Next &rarr;</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- else -%}
      <p>No products found in this collection yet.</p>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Collection product grid",
  "settings": [
    { "type": "checkbox", "id": "show_heading", "label": "Show collection title/description", "default": true },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 3 },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 4, "max": 48, "step": 4, "default": 16 }
  ]
}
{% endschema %}
