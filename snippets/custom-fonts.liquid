{%- comment -%}
  Bubba's brand type system — all three fonts loaded from licensed files
  in this theme's /assets, no dependency on Shopify's font_picker/font_face
  system (which only works with Shopify-hosted font objects, not our own
  uploaded files — that mismatch caused the earlier "font drop" Liquid error).
{%- endcomment -%}

<style>
  @font-face {
    font-family: 'Allora';
    src: url('{{ 'allora.woff2' | asset_url }}') format('woff2'),
         url('{{ 'allora.woff' | asset_url }}') format('woff');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Alosta';
    src: url('{{ 'alosta.woff2' | asset_url }}') format('woff2'),
         url('{{ 'alosta.woff' | asset_url }}') format('woff');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Raleway';
    src: url('{{ 'raleway.woff2' | asset_url }}') format('woff2-variations'),
         url('{{ 'raleway.woff' | asset_url }}') format('woff');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --font-heading: 'Allora', Georgia, serif;
    --font-subheading: 'Alosta', Helvetica, sans-serif;
    --font-body: 'Raleway', Helvetica, sans-serif;
  }
</style>
